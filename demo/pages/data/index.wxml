<view class="data-header">
  <text class="data-title">数据总览</text>
  <view class="data-summary">
    <view class="summary-item">
      <text class="summary-value">{{stats.totalCheckins}}</text>
      <text class="summary-label">累计打卡</text>
    </view>
    <view class="summary-item">
      <text class="summary-value">{{stats.totalRoutes}}</text>
      <text class="summary-label">完成线路</text>
    </view>
    <view class="summary-item">
      <text class="summary-value">{{stats.totalMinutes}}h</text>
      <text class="summary-label">攀爬时长</text>
    </view>
  </view>
</view>

<view class="chart-card">
  <view class="chart-header">
    <text class="chart-title">周趋势</text>
    <text class="chart-period">近7天</text>
  </view>
  <view class="chart-area">
    <view class="chart-bar-wrapper">
      <view class="chart-bar" style="height:{{stats.weeklyData[0]*0.8}}px;"></view>
      <text class="chart-label">一</text>
    </view>
    <view class="chart-bar-wrapper">
      <view class="chart-bar" style="height:{{stats.weeklyData[1]*0.8}}px;"></view>
      <text class="chart-label">二</text>
    </view>
    <view class="chart-bar-wrapper">
      <view class="chart-bar" style="height:{{stats.weeklyData[2]*0.8}}px;"></view>
      <text class="chart-label">三</text>
    </view>
    <view class="chart-bar-wrapper">
      <view class="chart-bar" style="height:{{stats.weeklyData[3]*0.8}}px;"></view>
      <text class="chart-label">四</text>
    </view>
    <view class="chart-bar-wrapper">
      <view class="chart-bar active" style="height:{{stats.weeklyData[4]*0.8}}px;"></view>
      <text class="chart-label">五</text>
    </view>
    <view class="chart-bar-wrapper">
      <view class="chart-bar" style="height:{{stats.weeklyData[5]*0.8}}px;"></view>
      <text class="chart-label">六</text>
    </view>
    <view class="chart-bar-wrapper">
      <view class="chart-bar" style="height:{{stats.weeklyData[6]*0.8}}px;"></view>
      <text class="chart-label">日</text>
    </view>
  </view>
</view>

<view class="section-title">本月成就</view>
<view class="achievements">
  <view class="achievement-card">
    <text class="achievement-icon">热</text>
    <text class="achievement-value">连续7天</text>
    <text class="achievement-label">坚持打卡</text>
  </view>
  <view class="achievement-card">
    <text class="achievement-icon">新</text>
    <text class="achievement-value">15条</text>
    <text class="achievement-label">新线路完成</text>
  </view>
  <view class="achievement-card">
    <text class="achievement-icon">榜</text>
    <text class="achievement-value">Top 15%</text>
    <text class="achievement-label">排名提升</text>
  </view>
</view>

<view class="card ranking-card">
  <view class="ranking-header">
    <text class="card-title">好友排行榜</text>
    <text class="card-link">查看全部</text>
  </view>
  <view class="ranking-list">
    <view class="ranking-item">
      <view class="rank rank-gold">1</view>
      <view class="rank-avatar">1</view>
      <text class="rank-name">陈大力</text>
      <text class="rank-value">28次/周</text>
    </view>
    <view class="ranking-item">
      <view class="rank rank-silver">2</view>
      <view class="rank-avatar green">2</view>
      <text class="rank-name">小明</text>
      <text class="rank-value">21次/周</text>
    </view>
    <view class="ranking-item">
      <view class="rank rank-bronze">3</view>
      <view class="rank-avatar pink">3</view>
      <text class="rank-name">小美</text>
      <text class="rank-value">18次/周</text>
    </view>
    <view class="ranking-item">
      <view class="rank">4</view>
      <view class="rank-avatar purple">4</view>
      <text class="rank-name">阿杰</text>
      <text class="rank-value">15次/周</text>
    </view>
  </view>
</view>
