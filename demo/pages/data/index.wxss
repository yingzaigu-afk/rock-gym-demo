.data-header {
  padding: 16px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}
.data-title {
  display: block;
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 16px;
}
.data-summary {
  display: flex;
  gap: 16px;
}
.summary-item {
  flex: 1;
  text-align: center;
}
.summary-value {
  display: block;
  font-size: 28px;
  font-weight: 700;
}
.summary-label {
  display: block;
  font-size: 12px;
  opacity: 0.8;
  margin-top: 4px;
}
.chart-card {
  background: white;
  border-radius: 12px;
  margin: 16px;
  padding: 16px;
}
.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.chart-title {
  font-size: 14px;
  font-weight: 600;
  color: #2D3436;
}
.chart-period {
  font-size: 12px;
  color: #6C757D;
  background: #F8F9FA;
  padding: 4px 8px;
  border-radius: 4px;
}
.chart-area {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 120px;
  padding-top: 20px;
}
.chart-bar-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.chart-bar {
  width: 24px;
  background: #FF6B35;
  border-radius: 4px 4px 0 0;
  opacity: 0.3;
  min-height: 20px;
}
.chart-bar.active {
  opacity: 1;
}
.chart-label {
  font-size: 10px;
  color: #6C757D;
  margin-top: 8px;
}
.achievements {
  display: flex;
  gap: 12px;
  padding: 0 16px;
  margin-bottom: 16px;
}
.achievement-card {
  flex: 1;
  background: white;
  border-radius: 12px;
  padding: 16px;
  text-align: center;
}
.achievement-icon {
  display: block;
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 8px;
}
.achievement-value {
  display: block;
  font-size: 16px;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 4px;
}
.achievement-label {
  display: block;
  font-size: 12px;
  color: #6C757D;
}
.ranking-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 16px 12px;
}
.ranking-list {
  padding: 0 16px 16px;
}
.ranking-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 0;
}
.rank {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
  background: #F8F9FA;
  color: #6C757D;
}
.rank-gold { background: #FFF3CD; color: #B8860B; }
.rank-silver { background: #E9ECEF; color: #6C757D; }
.rank-bronze { background: #FFE4C4; color: #CD7F32; }
.rank-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #FF6B35;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: bold;
  color: white;
}
.rank-avatar.green { background: #28A745; }
.rank-avatar.pink { background: #E91E63; }
.rank-avatar.purple { background: #9C27B0; }
.rank-name {
  flex: 1;
  font-size: 14px;
  color: #2D3436;
}
.rank-value {
  font-size: 14px;
  font-weight: 600;
  color: #FF6B35;
}
