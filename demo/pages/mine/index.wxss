.profile-header {
  padding: 24px 16px;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  color: white;
  display: flex;
  gap: 16px;
  align-items: center;
}
.profile-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: bold;
  border: 3px solid rgba(255, 255, 255, 0.5);
}
.profile-info {
  flex: 1;
}
.profile-name {
  display: block;
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 4px;
}
.profile-phone {
  display: block;
  font-size: 13px;
  opacity: 0.8;
  margin-bottom: 8px;
}
.member-badge {
  display: inline-block;
  padding: 4px 10px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12px;
  font-size: 12px;
}
.member-card-container {
  padding: 16px;
  margin-top: -20px;
}
.member-card-content {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  border-radius: 12px;
  padding: 16px;
  color: white;
}
.member-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}
.member-type {
  font-size: 14px;
}
.member-card-header .member-expiry {
  font-size: 12px;
  opacity: 0.8;
}
.member-card-stats {
  display: flex;
  gap: 24px;
}
.member-stat {
  text-align: center;
}
.member-stat-value {
  display: block;
  font-size: 24px;
  font-weight: 700;
}
.member-stat-label {
  display: block;
  font-size: 12px;
  opacity: 0.8;
  margin-top: 4px;
}
.menu-section {
  padding: 16px 0;
}
.menu-title {
  display: block;
  font-size: 13px;
  color: #6C757D;
  padding: 0 16px;
  margin-bottom: 8px;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background: white;
}
.menu-icon {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: bold;
  margin-right: 12px;
}
.menu-icon.orange { background: #FFF0ED; color: #FF6B35; }
.menu-icon.green { background: #E8F5E9; color: #28A745; }
.menu-icon.blue { background: #E3F2FD; color: #17A2B8; }
.menu-icon.purple { background: #F3E5F5; color: #9C27B0; }
.menu-icon.yellow { background: #FFF3CD; color: #856404; }
.menu-icon.gray { background: #E9ECEF; color: #6C757D; }
.menu-icon.light-gray { background: #F8F9FA; color: #6C757D; }
.menu-label {
  flex: 1;
  font-size: 15px;
  color: #2D3436;
}
.menu-badge {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 10px;
  background: #DC3545;
  color: white;
  margin-right: 8px;
}
.menu-arrow {
  color: #ADB5BD;
  font-size: 14px;
}
.logout {
  padding: 24px 16px;
}
.logout .btn {
  width: 100%;
  color: #6C757D;
}
