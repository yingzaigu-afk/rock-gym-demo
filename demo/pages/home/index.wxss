.home-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  padding: 16px;
  color: white;
}
.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16px;
}
.header-left {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.greeting {
  font-size: 24px;
  font-weight: 700;
}
.member-tag {
  display: inline-block;
  padding: 4px 10px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12px;
  font-size: 12px;
}
.notification-btn {
  font-size: 14px;
  padding: 8px;
}
.member-card {
  background: rgba(255, 255, 255, 0.3);
  border-radius: 12px;
  padding: 16px;
}
.member-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}
.member-label {
  font-size: 14px;
  font-weight: 500;
}
.member-expiry {
  font-size: 12px;
  opacity: 0.8;
}
.member-stats {
  display: flex;
  justify-content: space-around;
}
.stat-item {
  text-align: center;
}
.stat-value {
  display: block;
  font-size: 24px;
  font-weight: 700;
}
.stat-label {
  display: block;
  font-size: 12px;
  opacity: 0.8;
  margin-top: 4px;
}
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 16px;
  margin-top: -20px;
}
.quick-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.action-icon {
  width: 56px;
  height: 56px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: bold;
}
.action-icon.orange { background: #FFF0ED; color: #FF6B35; }
.action-icon.green { background: #E8F5E9; color: #28A745; }
.action-icon.blue { background: #E3F2FD; color: #17A2B8; }
.action-icon.purple { background: #F3E5F5; color: #9C27B0; }
.action-label {
  font-size: 12px;
  color: #6C757D;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 16px 12px;
}
.card-title {
  font-size: 16px;
  font-weight: 600;
  color: #2D3436;
}
.card-link {
  font-size: 13px;
  color: #FF6B35;
}
.course-list {
  padding: 0 16px 16px;
}
.course-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 0;
  border-top: 1px solid #E9ECEF;
}
.course-item:first-child {
  border-top: none;
  padding-top: 0;
}
.course-date {
  width: 48px;
  text-align: center;
  flex-shrink: 0;
}
.date-day {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: #FF6B35;
}
.date-month {
  display: block;
  font-size: 12px;
  color: #6C757D;
}
.course-info {
  flex: 1;
}
.course-title {
  display: block;
  font-size: 15px;
  font-weight: 500;
  color: #2D3436;
  margin-bottom: 4px;
}
.course-meta {
  display: block;
  font-size: 13px;
  color: #6C757D;
}
.course-status {
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
  background: #E8F5E9;
  color: #28A745;
}
.course-status.pending {
  background: #FFF3CD;
  color: #856404;
}
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  padding: 0 16px;
  margin-bottom: 16px;
}
.stat-card {
  width: calc(50% - 6px);
  background: white;
  border-radius: 12px;
  padding: 16px;
  box-sizing: border-box;
}
.stat-icon {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 12px;
}
.stat-icon.orange { background: #FFF0ED; color: #FF6B35; }
.stat-icon.green { background: #E8F5E9; color: #28A745; }
.stat-icon.blue { background: #E3F2FD; color: #17A2B8; }
.stat-icon.purple { background: #F3E5F5; color: #9C27B0; }
.stat-card-value {
  display: block;
  font-size: 20px;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 4px;
}
.stat-card-label {
  display: block;
  font-size: 12px;
  color: #6C757D;
}
