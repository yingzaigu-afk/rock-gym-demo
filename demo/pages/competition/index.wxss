.tabs {
  display: flex;
  padding: 0 16px;
  border-bottom: 1px solid #E9ECEF;
  background: white;
}
.tab {
  padding: 12px 16px;
  font-size: 15px;
  font-weight: 500;
  color: #6C757D;
  position: relative;
}
.tab.active {
  color: #FF6B35;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  right: 0;
  height: 2px;
  background: #FF6B35;
}
.competition-card {
  padding: 0;
}
.competition-img {
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.competition-img-orange { background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%); }
.competition-img-green { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); }
.competition-img-purple { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.competition-emoji {
  font-size: 48px;
  font-weight: bold;
  color: white;
}
.competition-status {
  position: absolute;
  top: 12px;
  right: 12px;
  padding: 4px 10px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.9);
  color: #FF6B35;
}
.competition-status.upcoming {
  color: #17A2B8;
}
.competition-status.ended {
  background: rgba(0, 0, 0, 0.5);
  color: white;
}
.competition-body {
  padding: 16px;
}
.competition-title {
  display: block;
  font-size: 17px;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 8px;
}
.competition-meta {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: 12px;
}
.meta-item {
  font-size: 13px;
  color: #6C757D;
}
.competition-projects {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}
.project-tag {
  padding: 4px 10px;
  border-radius: 4px;
  font-size: 12px;
  background: #F8F9FA;
  color: #6C757D;
}
.competition-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.competition-price {
  font-size: 20px;
  font-weight: 700;
  color: #FF6B35;
}
.competition-price.free {
  color: #28A745;
}
.btn-sm {
  width: 100px;
  height: 36px;
  font-size: 14px;
}
