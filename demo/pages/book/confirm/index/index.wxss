.success-container {
  padding: 60px 16px 32px;
  text-align: center;
}
.success-icon {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: #E8F5E9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24px;
  font-size: 32px;
  font-weight: bold;
  color: #28A745;
}
.success-title {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 8px;
}
.success-desc {
  display: block;
  font-size: 14px;
  color: #6C757D;
}
.booking-details {
  background: white;
  border-radius: 12px;
  margin: 0 16px 24px;
  padding: 20px;
}
.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #E9ECEF;
}
.detail-row:last-child {
  border-bottom: none;
}
.detail-label {
  color: #6C757D;
  font-size: 14px;
}
.detail-value {
  color: #2D3436;
  font-weight: 500;
}
.detail-total {
  border-top: 1px dashed #E9ECEF;
  padding-top: 16px;
  margin-top: 4px;
}
.detail-amount {
  font-size: 20px;
  font-weight: 700;
  color: #FF6B35;
}
.actions {
  padding: 0 16px;
}
.actions .btn {
  margin-bottom: 12px;
}
.tips {
  margin: 24px 16px;
  padding: 16px;
  background: #FFF3CD;
  border-radius: 12px;
}
.tip-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #856404;
  margin-bottom: 4px;
}
.tip-desc {
  display: block;
  font-size: 13px;
  color: #856404;
}
