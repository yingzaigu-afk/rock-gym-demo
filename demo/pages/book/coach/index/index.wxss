.coach-list {
  padding-top: 16px;
}
.coach-card {
  display: flex;
  gap: 12px;
  padding: 16px;
  padding-bottom: 12px;
}
.coach-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: bold;
  flex-shrink: 0;
}
.coach-avatar-orange { background: #FF6B35; color: white; }
.coach-avatar-green { background: #28A745; color: white; }
.coach-avatar-blue { background: #17A2B8; color: white; }
.coach-info {
  flex: 1;
}
.coach-name {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 8px;
}
.coach-tags {
  display: flex;
  gap: 6px;
  margin-bottom: 8px;
}
.tag {
  font-size: 11px;
  padding: 2px 6px;
  border-radius: 4px;
  background: #FFF0ED;
  color: #FF6B35;
}
.coach-rating {
  display: flex;
  align-items: center;
  gap: 4px;
}
.rating-text {
  font-size: 13px;
  color: #6C757D;
}
.coach-price {
  text-align: right;
}
.price {
  font-size: 18px;
  font-weight: 700;
  color: #FF6B35;
}
.price-unit {
  font-size: 12px;
  color: #6C757D;
}
.auto-assign {
  padding: 24px 16px;
  text-align: center;
}
.auto-desc {
  display: block;
  font-size: 12px;
  color: #6C757D;
  margin-top: 8px;
}
